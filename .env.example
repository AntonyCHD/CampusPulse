# API Configuration
API_BASE_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Alternative LLM Providers (Optional)
# DEEPSEEK_API_KEY=your_deepseek_key
# QWEN_API_KEY=your_qwen_key

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# Vector Store
VECTOR_STORE_PATH=./cache/vector_store
CHROMA_PERSIST_DIRECTORY=./cache/chroma_db

# Database
DB_PATH=./data/campus_opinion.db

# Cache Configuration
ENABLE_CACHE=true
CACHE_DIR=./cache
LLM_CACHE_DIR=./cache/llm_responses
DEMO_CACHE_DIR=./cache/demo_reports

# Logging
LOG_LEVEL=INFO
LOG_FILE=./outputs/logs/app.log

# Analysis Configuration
TOP_N_COMMENTS=20
SEMANTIC_THRESHOLD=0.80
TOPIC_THRESHOLD=0.78
RESONANCE_THRESHOLD=0.55

# Safety & Privacy
ENABLE_ANONYMIZATION=true
SALT_KEY=your_random_salt_here

# Demo Mode
DEFAULT_MODE=cached
